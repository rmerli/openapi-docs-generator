{
    "name": "rmerli/openapi-docs-generator",
    "description": "Automatic OpenAPI documentation generator from Spatie Laravel Data DTOs",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "doctrine/annotations": "^2.0",
        "zircote/swagger-php": "^4.0",
        "spatie/laravel-data": "^3.9|^4.0",
        "symfony/yaml": "^6.0|^7.0"
    },
    "authors": [
        {
          "role": "Developer",
          "name": "Humberto Cuadra",
          "email": "hcuadra@flexmarkintl.com"
        }
    ],
    "minimum-stability": "dev",
    "autoload": {
        "psr-4": {
            "Langsys\\OpenApiDocsGenerator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Langsys\\OpenApiDocsGenerator\\Tests\\": "tests/",
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Langsys\\OpenApiDocsGenerator\\OpenApiDocsServiceProvider"
            ],
            "aliases": {
                "OpenApiDocs": "Langsys\\OpenApiDocsGenerator\\OpenApiDocsFacade"
            }
        }
    },
    "require-dev": {
        "pestphp/pest": "^2.0|^3.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
